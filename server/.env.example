DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-in-production"
PORT=3001

# Open-source local LLM via Ollama (https://ollama.com)
# 1. Install Ollama  2. ollama pull llama3.1:8b  3. ollama serve
LLM_BASE_URL="http://127.0.0.1:11434"
LLM_MODEL="llama3.1:8b"
LLM_PROVIDER="ollama"
# LLM_AGENT_ENABLED="true"
# LLM_API_KEY="ollama"
